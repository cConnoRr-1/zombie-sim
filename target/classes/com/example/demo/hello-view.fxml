<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>

<AnchorPane id="AnchorPane" fx:id="aPane" prefHeight="755.0" prefWidth="1367.0" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.HelloController">
   <children>

      <GridPane fx:id="gPane" layoutX="49.0" layoutY="31.0" prefHeight="0.0" prefWidth="0.0">

      </GridPane>
      <TitledPane animated="false" layoutX="1079.0" layoutY="44.0" prefHeight="170.0" prefWidth="202.0" text="Setting">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
               <children>
                  <TextField fx:id="amountOfHumText" layoutX="2.0" layoutY="2.0" prefHeight="26.0" prefWidth="97.0" promptText="num of human" />
                  <TextField fx:id="amountOfZomText" layoutX="3.0" layoutY="32.0" prefHeight="26.0" prefWidth="97.0" promptText="num of zombie" />
                  <Button fx:id="setBombBtn" layoutX="3.0" layoutY="64.0" mnemonicParsing="false" onAction="#handleSetBomb" prefHeight="26.0" prefWidth="124.0" text="Bomb" />
                  <Button fx:id="addHumanBtn" layoutX="104.0" layoutY="1.0" mnemonicParsing="false" onAction="#handleAddHuman" text="Add Humans" />
                  <Button fx:id="addZombBtn" layoutX="104.0" layoutY="31.0" mnemonicParsing="false" onAction="#handleAddZomb" text="add zombies" />
               </children>
            </AnchorPane>
        </content>
      </TitledPane>
      <Button fx:id="button" layoutX="1079.0" layoutY="19.0" onAction="#handleStart" text="Start Simulation" />
      <ListView fx:id="showStatsListView" layoutX="1080.0" layoutY="224.0" prefHeight="206.0" prefWidth="200.0" />
      <Button fx:id="resetBtn" layoutX="1192.0" layoutY="17.0" mnemonicParsing="false" onAction="#handleReset" text="reset" />
      <BarChart fx:id="showPopulationBC" layoutX="1018.0" layoutY="438.0" prefHeight="222.0" prefWidth="315.0">
        <xAxis>
          <CategoryAxis side="BOTTOM" />
        </xAxis>
        <yAxis>
          <NumberAxis side="LEFT" />
        </yAxis>
      </BarChart>


   </children>
</AnchorPane>
